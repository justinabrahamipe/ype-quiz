generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  user
  quizmaster
  admin
}

enum AnswerType {
  text
  number
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  name           String?
  image          String?
  role           Role          @default(user)
  isQualified    Boolean       @default(false)
  isApproved     Boolean       @default(true)
  createdAt      DateTime      @default(now())
  attempts       Attempt[]
  quizzesCreated Quiz[]
  overallScore   OverallScore?
}

model AppSettings {
  id          Int     @id @default(1)
  openSignup  Boolean @default(false)
}

model Quiz {
  id               String     @id @default(uuid())
  title            String
  biblePortion     String
  startTime        DateTime
  endTime          DateTime
  questionCount    Int
  isPrerequisite   Boolean    @default(false)
  createdBy        String
  creator          User       @relation(fields: [createdBy], references: [id])
  createdAt        DateTime   @default(now())
  questions        Question[]
  attempts         Attempt[]
  penaltyProcessed Boolean    @default(false)
  resultsProcessed Boolean    @default(false)
}

model Question {
  id              String     @id @default(uuid())
  quizId          String
  quiz            Quiz       @relation(fields: [quizId], references: [id])
  questionText    String
  answerType      AnswerType
  acceptedAnswers String[]
  orderIndex      Int
  answers         Answer[]
}

model Attempt {
  id          String    @id @default(uuid())
  quizId      String
  quiz        Quiz      @relation(fields: [quizId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  rawScore    Decimal?
  bonusPoints Decimal   @default(0)
  isComplete  Boolean   @default(false)
  archivedAt  DateTime?
  answers     Answer[]

  @@unique([quizId, userId])
}

model Answer {
  id               String    @id @default(uuid())
  attemptId        String
  attempt          Attempt   @relation(fields: [attemptId], references: [id])
  questionId       String
  question         Question  @relation(fields: [questionId], references: [id])
  submittedText    String?
  isCorrect        Boolean?
  answeredAt       DateTime  @default(now())
  timeTakenSeconds Int?
}

model OverallScore {
  userId           String   @id
  user             User     @relation(fields: [userId], references: [id])
  totalScore       Decimal  @default(0)
  quizzesAttempted Int      @default(0)
  quizzesMissed    Int      @default(0)
  lastUpdated      DateTime @updatedAt
}
